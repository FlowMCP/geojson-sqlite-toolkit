{
    "name": "geojson-sqlite-toolkit",
    "version": "0.1.0",
    "type": "module",
    "description": "FlowMCP add-on: fetch a complete GeoJSON FeatureCollection (RFC 7946) by URL, hold it in memory, and query it with reusable spatial methods (featuresInBBox, nearPoint, byType)",
    "main": "src/index.mjs",
    "license": "MIT",
    "author": "FlowMCP",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/FlowMCP/geojson-sqlite-toolkit.git"
    },
    "bugs": {
        "url": "https://github.com/FlowMCP/geojson-sqlite-toolkit/issues"
    },
    "homepage": "https://github.com/FlowMCP/geojson-sqlite-toolkit#readme",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
        "test:coverage:src": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
        "test:manual": "node tests/manual/run-all.mjs"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "jest": "^30.0.0"
    }
}
